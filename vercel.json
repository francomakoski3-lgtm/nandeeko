{
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.nandeeko.com"
        }
      ],
      "destination": "https://nandeeko.com/:path*",
      "permanent": true
    }
  ]
}
